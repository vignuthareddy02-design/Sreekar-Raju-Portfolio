rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Read access is public for Sreekar's gallery assets, narrative stories, timeline, and GPS map markers.
    // Write permissions are exclusively restricted to vignuthareddy02@gmail.com.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'vignuthareddy02@gmail.com';
    }
  }
}
